{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Axctl Universal Wayland RPC Schema",
  "description": "Universal JSON-RPC structures for Axctl to interact with Wayland compositors (Hyprland, Niri, Mango, etc.)",
  "type": "object",
  "definitions": {
    "Monitor": {
      "type": "object",
      "description": "Represents a physical or virtual output device.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Universal string identifier for the monitor (e.g. '1', 'DP-1'). Normalized to avoid QML type issues."
        },
        "name": {
          "type": "string",
          "description": "Port or display name (e.g., HDMI-A-1)."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the monitor."
        },
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        },
        "refresh_rate": {
          "type": "number"
        },
        "scale": {
          "type": "number",
          "description": "Display scaling factor."
        },
        "is_focused": {
          "type": "boolean",
          "description": "Whether this monitor currently has the focused workspace/window."
        },
        "metadata": {
          "type": "object",
          "description": "Compositor-specific metadata (e.g., 'hyprland_address', 'niri_id')."
        }
      },
      "required": [
        "id",
        "name",
        "width",
        "height",
        "is_focused"
      ],
      "additionalProperties": false
    },
    "Workspace": {
      "type": "object",
      "description": "Represents a virtual workspace or tag.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Universal string identifier for the workspace (e.g., '1', 'sys')."
        },
        "name": {
          "type": "string",
          "description": "Display name of the workspace."
        },
        "monitor_id": {
          "type": "string",
          "description": "ID of the monitor this workspace belongs to."
        },
        "is_active": {
          "type": "boolean",
          "description": "Whether the workspace is currently active and visible on its monitor."
        },
        "is_empty": {
          "type": "boolean",
          "description": "Whether the workspace has no windows mapped to it."
        },
        "metadata": {
          "type": "object",
          "description": "Compositor-specific metadata."
        }
      },
      "required": [
        "id",
        "name",
        "monitor_id",
        "is_active"
      ],
      "additionalProperties": false
    },
    "Window": {
      "type": "object",
      "description": "Represents a client window or view.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Universal string identifier for the window (e.g., '0x55f9a', '42')."
        },
        "title": {
          "type": "string",
          "description": "Current title of the window."
        },
        "app_id": {
          "type": "string",
          "description": "Wayland app_id or X11 class."
        },
        "workspace_id": {
          "type": "string",
          "description": "ID of the workspace this window belongs to."
        },
        "is_focused": {
          "type": "boolean",
          "description": "Whether the window currently has keyboard focus."
        },
        "is_floating": {
          "type": "boolean",
          "description": "Whether the window is floating/detached from the tiling grid."
        },
        "is_fullscreen": {
          "type": "boolean",
          "description": "Whether the window is in fullscreen state."
        },
        "is_hidden": {
          "type": "boolean",
          "description": "Whether the window is minimized or hidden."
        },
        "metadata": {
          "type": "object",
          "description": "Compositor-specific metadata (e.g., 'hyprland_address')."
        }
      },
      "required": [
        "id",
        "title",
        "app_id",
        "workspace_id",
        "is_focused"
      ],
      "additionalProperties": false
    },
    "Capabilities": {
      "type": "object",
      "description": "Flags indicating features supported by the current compositor.",
      "properties": {
        "blur": {
          "type": "boolean"
        },
        "shadows": {
          "type": "boolean"
        },
        "animations": {
          "type": "boolean"
        },
        "rounded_corners": {
          "type": "boolean"
        },
        "workspaces_supported": {
          "type": "boolean"
        },
        "windows_supported": {
          "type": "boolean"
        }
      },
      "required": [
        "blur",
        "shadows",
        "animations",
        "rounded_corners",
        "workspaces_supported",
        "windows_supported"
      ],
      "additionalProperties": false
    },
    "CompositorState": {
      "type": "object",
      "description": "Root state structure representing the entire Wayland desktop environment.",
      "properties": {
        "monitors": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Monitor"
          }
        },
        "workspaces": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Workspace"
          }
        },
        "windows": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Window"
          }
        },
        "capabilities": {
          "$ref": "#/definitions/Capabilities"
        }
      },
      "required": [
        "monitors",
        "workspaces",
        "windows",
        "capabilities"
      ],
      "additionalProperties": false
    }
  }
}
